define DemProxSgNom [ [ {ай} "+PRON+PronType=Dem+Deixis=Prox+Number=Sing+Case=Nom" .x. {а} ] | [ {ай} "+PRON+PronType=Dem+Deixis=Prox+Number=Sing+Case=Nom" .x. {ай} ] | [ {а} "+PRON+PronType=Dem+Deixis=Prox+Number=Sing+Case=Nom" .x. {йай} ] ] ;
define DemProxSgGen [ [ {ай} "+PRON+PronType=Dem+Deixis=Prox+Number=Sing+Case=Gen" .x. {ай} ] ] ;
define DemProxSgDat [ [ {ай} "+PRON+PronType=Dem+Deixis=Prox+Number=Sing+Case=Dat" .x. {амӕн} ] ] ;
define DemProxSgAll [ [ {ай} "+PRON+PronType=Dem+Deixis=Prox+Number=Sing+Case=All" .x. {амӕ} ] ] ;
define DemProxSgIne [ [ {ай} "+PRON+PronType=Dem+Deixis=Prox+Number=Sing+Case=Ine" .x. {ам} ] ] ;
define DemProxSgAbl [ [ {ай} "+PRON+PronType=Dem+Deixis=Prox+Number=Sing+Case=Abl" .x. {амӕй} ] ] ;
define DemProxSgSup [ [ {ай} "+PRON+PronType=Dem+Deixis=Prox+Number=Sing+Case=Sup" .x. {айыл} ] ] ;
define DemProxSgEqu [ [ {ай} "+PRON+PronType=Dem+Deixis=Prox+Number=Sing+Case=Equ" .x. {айау} ] ] ;
define DemProxSgCom [ [ {ай} "+PRON+PronType=Dem+Deixis=Prox+Number=Sing+Case=Com" .x. {аимӕ} ] ] ;
define DemProxSgDir [ [ {ай} "+PRON+PronType=Dem+Deixis=Prox+Number=Sing+Case=Dir" .x. {ардӕм} ] ] ;
define DemProxSgRcs [ [ {ай} "+PRON+PronType=Dem+Deixis=Prox+Number=Sing+Case=Rcs" .x. {ардыгӕй} ] ] ;
define DemProx [ DemProxSgNom | DemProxSgGen | DemProxSgDat | DemProxSgAll | DemProxSgAbl | DemProxSgIne | DemProxSgSup | DemProxSgEqu | DemProxSgCom | DemProxSgDir | DemProxSgRcs ] ;

### DemRemt
define DemRemtSgNom [ [ {уый} "+PRON+PronType=Dem+Deixis=Remt+Number=Sing+Case=Nom" .x. {уый} ] ] ;
define DemRemtSgGen [ [ {уый} "+PRON+PronType=Dem+Deixis=Remt+Number=Sing+Case=Gen" .x. {уый} ] | [ {уый} "+PRON+PronType=Dem+Deixis=Remt+Number=Sing+Case=Gen" .x. {уыйы} ] | [ {уый} "+PRON+PronType=Dem+Deixis=Remt+Number=Sing+Case=Gen" .x. {уой} ] ] ;
define DemRemtSgDat [ [ {уый} "+PRON+PronType=Dem+Deixis=Remt+Number=Sing+Case=Dat" .x. {уымӕн} ] ] ;
define DemRemtSgAll [ [ {уый} "+PRON+PronType=Dem+Deixis=Remt+Number=Sing+Case=All" .x. {уымӕ} ] ] ;
define DemRemtSgIne [ [ {уый} "+PRON+PronType=Dem+Deixis=Remt+Number=Sing+Case=Ine" .x. {уым} ] ] ;
define DemRemtSgAbl [ [ {уый} "+PRON+PronType=Dem+Deixis=Remt+Number=Sing+Case=Abl" .x. {уымӕй} ] ] ;
define DemRemtSgSup [ [ {уый} "+PRON+PronType=Dem+Deixis=Remt+Number=Sing+Case=Sup" .x. {ууыл} ] ] ;
define DemRemtSgEqu [ [ {уый} "+PRON+PronType=Dem+Deixis=Remt+Number=Sing+Case=Equ" .x. {уыйау} ] ] ;
define DemRemtSgCom [ [ {уый} "+PRON+PronType=Dem+Deixis=Remt+Number=Sing+Case=Com" .x. {уыимӕ} ] | [ {уыимӕ} "+PRON+PronType=Dem+Deixis=Remt+Number=Sing+Case=Com" .x. {уыйимӕ} ] ] ;
define DemRemtSgDir [ [ {уый} "+PRON+PronType=Dem+Deixis=Remt+Number=Sing+Case=Dir" .x. {уырдӕм} ] ] ;
define DemRemtSgRcs [ [ {уый} "+PRON+PronType=Dem+Deixis=Remt+Number=Sing+Case=Rcs" .x. {уырдыгӕй} ] ] ;
define DemRemt [ DemRemtSgNom | DemRemtSgGen | DemRemtSgDat | DemRemtSgAll | DemRemtSgAbl | DemRemtSgIne | DemRemtSgSup | DemRemtSgEqu | DemRemtSgCom | DemRemtSgDir | DemRemtSgRcs ] ;

define Adaem [ {адӕймаг} "+NOUN+Number=Plur+Case=Nom" .x. {адӕм} ] ;

define Exceptions [ PronPrs | be | beV | Int | Ind | Ind2 | Ind3 | Tot | Neg | Neg2 | DemProx | DemRemt | Adaem ] ;

read lexc oss_proto.lexc
define Lexicon;

define Grammar Lexicon .o.
               YInsertion .o.
			   JInsertion .o.
			   ExAbl .o.
               Cleanup .o.
			   NCleanup ;
			   
#push Grammar

define Analyzer Exceptions .P. Grammar ;
			   
push Analyzer