define YInsertion [..] -> ы || C _ "$" т ;

define JInsertion [..] -> й || V "$" _ V ;

define ExAbl й -> 0 || V "$" й ӕ _ ;

define NCleanup "$" -> 0 ;

define Cleanup "^" -> 0;

